          "name": "List Batches",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/batches?status=",
              "host": ["{{baseUrl}}"], "path": ["api","batches"],
              "query": [
                { "key": "status", "value": "", "description": "Received | Loaded | Drying | Completed | Delivered" },
                { "key": "q", "value": "", "disabled": true }
