          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/arrivals",
            "body": { "mode": "raw", "raw": "{\n  \"customer_id\": \"{{customerId}}\",\n  \"product_id\": \"{{productId}}\",\n  \"raw_weight\": 250,\n  \"bags\": 12,\n  \"arrival_date\": \"2026-07-12\",\n  \"rate_per_kg\": 15,\n  \"received_from\": \"Ravi (driver)\",\n  \"branch_id\": \"{{branchId}}\",\n  \"remarks\": \"Freshly harvested\",\n  \"photos\": []\n}" }
          }
        },
        {
          "name": "Create Full Batch (advance + charges)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json(); if (j.id) pm.collectionVariables.set('batchId', j.id);"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/batches",
            "body": { "mode": "raw", "raw": "{\n  \"customer_id\": \"{{customerId}}\",\n  \"product_id\": \"{{productId}}\",\n  \"raw_weight\": 300,\n  \"estimated_dry_weight\": 220,\n  \"moisture\": 25,\n  \"bags\": 15,\n  \"bag_weight\": 20,\n  \"machine_id\": \"{{machineId}}\",\n  \"rate_per_kg\": 15,\n  \"loading_charges\": 100,\n  \"discount\": 0,\n  \"advance_paid\": 500,\n  \"remarks\": \"With advance\",\n  \"photos\": [],\n  \"branch_id\": \"{{branchId}}\"\n}" }
          }
        },
