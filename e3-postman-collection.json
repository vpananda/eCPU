{
  "info": {
    "name": "E3 — Post Harvest Processing Unit",
    "_postman_id": "e3-agro-2026-01",
    "description": "Complete API collection for the E3 drying plant management app. Login first — the token is auto-captured into the `token` collection variable and used by all subsequent requests.\n\n**Base URL:** set the `baseUrl` variable to your backend origin (e.g. `https://cardamom-batch-pro.preview.emergentagent.com` for the Emergent preview, or `http://localhost:8001` locally).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://cardamom-batch-pro.preview.emergentagent.com", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "customerId", "value": "", "type": "string" },
    { "key": "productId", "value": "", "type": "string" },
    { "key": "machineId", "value": "", "type": "string" },
    { "key": "branchId", "value": "", "type": "string" },
    { "key": "batchId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Admin)",
          "event": [
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "const j = pm.response.json();",
              "if (j.token) pm.collectionVariables.set('token', j.token);",
              "pm.test('Login OK', () => pm.expect(pm.response.code).to.eql(200));"
            ]}}
          ],
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"mobile\": \"9999999999\",\n  \"password\": \"admin123\"\n}" }
          }
        },
        {
          "name": "Login (Manager)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json(); if (j.token) pm.collectionVariables.set('token', j.token);"
          ]}}],
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"mobile\": \"8888888888\",\n  \"password\": \"manager123\"\n}" }
          }
        },
        {
          "name": "Login (Store Incharge)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json(); if (j.token) pm.collectionVariables.set('token', j.token);"
          ]}}],
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"mobile\": \"7777777777\",\n  \"password\": \"store123\"\n}" }
          }
        },
        {
          "name": "Google — Complete Sign-In",
          "request": {
            "method": "POST", "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/google",
            "body": { "mode": "raw", "raw": "{\n  \"session_token\": \"<emergent-session-token-from-frontend>\"\n}" },
            "description": "The frontend fetches the session_token from the Emergent OAuth callback and posts it here. Backend verifies with Emergent then upserts the user."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET", "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/api/auth/logout" }
        }
      ]
    },
    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "List Users",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "const j = pm.response.json();",
            "if (Array.isArray(j) && j[0]) pm.collectionVariables.set('userId', j[0].id);"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/auth/users" }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/users",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Priya M.\",\n  \"mobile\": \"9012345678\",\n  \"password\": \"priya123\",\n  \"role\": \"Manager\",\n  \"branch_id\": \"{{branchId}}\"\n}" }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/users/{{userId}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Priya Manager\",\n  \"role\": \"Manager\",\n  \"branch_id\": \"{{branchId}}\",\n  \"password\": \"newpass456\"\n}" }
          }
        },
        {
          "name": "Delete User",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/auth/users/{{userId}}" }
        }
      ]
    },
