          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/customers",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Suresh Naik\",\n  \"mobile\": \"9820011223\",\n  \"alt_mobile\": \"\",\n  \"village\": \"Sakleshpur\",\n  \"taluk\": \"Sakleshpur\",\n  \"district\": \"Hassan\",\n  \"address\": \"Estate #12\",\n  \"gst\": \"\",\n  \"remarks\": \"Regular grower\"\n}" }
